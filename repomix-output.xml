}

.react-flow__minimap-mask {
  fill: rgba(15, 23, 42, 0.85) !important;
}

.react-flow__handle {
  width: 6px !important;
  height: 6px !important;
  background-color: #475569 !important;
  border: 1px solid #64748b !important;
}

.react-flow__handle:hover {
  background-color: #22d3ee !important;
  border-color: #22d3ee !important;
}

.react-flow__selection {
  background: rgba(34, 211, 238, 0.08) !important;
  border: 1px solid rgba(34, 211, 238, 0.4) !important;
}

.react-flow__attribution { display: none !important; }

/* Scrollbars */
::-webkit-scrollbar { width: 8px; height: 8px; }
::-webkit-scrollbar-track { background: var(--bg-base); }
::-webkit-scrollbar-thumb { background: var(--border-default); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: var(--border-hover); }

.graph-canvas::-webkit-scrollbar { width: 6px; height: 6px; }
.graph-canvas::-webkit-scrollbar-track { background: #0f172a; }
.graph-canvas::-webkit-scrollbar-thumb { background: #334155; border-radius: 3px; }
.graph-canvas::-webkit-scrollbar-thumb:hover { background: #475569; }

.cypher-editor::-webkit-scrollbar { width: 6px; height: 6px; }
.cypher-editor::-webkit-scrollbar-track { background: transparent; }
.cypher-editor::-webkit-scrollbar-thumb { background: #334155; border-radius: 3px; }
.cypher-editor::-webkit-scrollbar-thumb:hover { background: #475569; }

.cypher-editor {
  scrollbar-width: thin;
  scrollbar-color: #334155 transparent;
}

.custom-scrollbar::-webkit-scrollbar { width: 6px; }
.custom-scrollbar::-webkit-scrollbar-track { background: rgb(15 23 42); border-radius: 3px; }
.custom-scrollbar::-webkit-scrollbar-thumb { background: rgb(51 65 85); border-radius: 3px; }
.custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgb(71 85 105); }

/* rrweb player */
.rr-player { max-width: 100% !important; }
.rr-player__frame { width: 100% !important; }
.rr-controller { position: relative !important; z-index: 50; }
.rr-player video, .rr-player iframe { max-width: 100%; }
.rr-player-wrapper { height: 55vh; }
@media (min-width: 1280px) { .rr-player-wrapper { height: 45vh; } }
@media (min-width: 1536px) { .rr-player-wrapper { height: 80vh; } }
